#include <stdio.h>
#include <stdlib.h>
#include <locale.h>
#include <string.h>

//===== STRUCTS =====//

struct Cliente {
    char nome[50];
    char cpf[30];
    char endereco[50];
    char telefone[30];
};

struct Vaga {
    int ocupada;
    char falecido[50];
};

struct Lote {
    struct Vaga vagas[2];
};

struct Quadra {
    struct Lote lotes[5];
};

//===== FUNÇÕES =====//

void cadastrarCliente(struct Cliente *c) {
    printf("\n--- Cadastrar Cliente ---\n");
    printf("Nome: ");
    scanf(" %[^\n]", c->nome);
    printf("CPF: ");
    scanf(" %[^\n]", c->cpf);
    printf("Endereço: ");
    scanf(" %[^\n]", c->endereco);
    printf("Telefone: ");
    scanf(" %[^\n]", c->telefone);
    printf("Cliente cadastrado!\n");
}

void cadastrarJazigo(struct Quadra quadras[]) {
    int q, l, v;

    printf("\n--- Cadastrar Jazigo ---\n");
    printf("Quadra (1 a 4): ");
    scanf("%d", &q);
    printf("Lote (1 a 5): ");
    scanf("%d", &l);
    printf("Vaga (1 a 2): ");
    scanf("%d", &v);

    // Validar entradas
    if (q < 1 || q > 4 || l < 1 || l > 5 || v < 1 || v > 2) {
        printf("Valores inválidos!\n");
        return;
    }

    q--; l--; v--;  // ajusta para índice do array

    if (quadras[q].lotes[l].vagas[v].ocupada == 1) {
        printf("Essa vaga já está ocupada!\n");
        return;
    }

    printf("Nome do falecido: ");
    scanf(" %[^\n]", quadras[q].lotes[l].vagas[v].falecido);
    quadras[q].lotes[l].vagas[v].ocupada = 1;

    printf("Jazigo Q%d-L%d-V%d cadastrado!\n", q+1, l+1, v+1);
}

void listarJazigos(struct Quadra quadras[]) {
    printf("\n--- Mapa do Cemitério ---\n");
    for (int q = 0; q < 4; q++) {
        printf("Quadra %d:\n", q + 1);
        for (int l = 0; l < 5; l++) {
            printf("  Lote %d: ", l + 1);
            for (int v = 0; v < 2; v++) {
                if (quadras[q].lotes[l].vagas[v].ocupada)
                    printf("[V%d: %s] ", v+1, quadras[q].lotes[l].vagas[v].falecido);
                else
                    printf("[V%d: LIVRE] ", v+1);
            }
            printf("\n");
        }
    }
}

//===== MAIN =====//

int main() {
    setlocale(LC_ALL, "portuguese");

    int opcao;
    struct Cliente cliente;
    struct Quadra quadras[4];  // 4 quadras

    // Inicializar todas as vagas como livres
    for (int q = 0; q < 4; q++)
        for (int l = 0; l < 5; l++)
            for (int v = 0; v < 2; v++) {
                quadras[q].lotes[l].vagas[v].ocupada = 0;
                strcpy(quadras[q].lotes[l].vagas[v].falecido, "");
            }

    do {
        printf("\n===== MENU PRINCIPAL =====\n");
        printf("1 - Cadastrar Cliente\n");
        printf("2 - Cadastrar Jazigo\n");
        printf("3 - Listar Jazigos\n");
        printf("4 - Sair\n");
        printf("Escolha: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1: cadastrarCliente(&cliente); break;
            case 2: cadastrarJazigo(quadras);   break;
            case 3: listarJazigos(quadras);     break;
            case 4: printf("Saindo...\n");      break;
            default: printf("Opção inválida!\n");
        }

    } while (opcao != 4);

    return 0;
}
